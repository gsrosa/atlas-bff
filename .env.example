# Supabase — Project Settings → API
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# Service role: server-only, never expose to browsers
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Comma-separated origins for CORS (no spaces). Use http://localhost:5173 for local Vite.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Google Gemini (server-side only — used by POST /plans/stream)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Optional: defaults to 4000 — tRPC at /trpc, plan AI stream at /plans/stream
PORT=4000

# Optional: set to production in deployed environments
NODE_ENV=development
