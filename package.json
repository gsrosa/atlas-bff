{
  "name": "atlas-bff",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "description": "Atlas backend-for-frontend — Express + tRPC with Supabase auth, users, and plans",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:migrate": "tsx scripts/apply-migrations.ts",
    "db:link": "supabase link --project-ref jznanszhrqrwzrxlmhko",
    "db:push": "supabase db push",
    "db:auth-rate-limits": "bash scripts/supabase-remote-auth-rate-limits.sh",
    "api:smoke": "tsx scripts/smoke-api.ts",
    "api:integration": "tsx scripts/integration-routes.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.49.1",
    "@trpc/server": "^11.15.1",
    "cookie": "^1.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "ioredis": "^5.10.1",
    "postgres": "^3.4.8",
    "superjson": "^2.2.6",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/cookie": "^1.0.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.13.10",
    "@types/supertest": "^7.2.0",
    "supertest": "^7.2.2",
    "tsup": "^8.5.1",
    "tsx": "^4.19.3",
    "typescript": "~5.9.3",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=20"
  }
}
